      "comment": "[Alert] Explanation for system symbol name",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入一个 [SF Symbol](https://developer.apple.com/sf-symbols/) 名称，参考[文档](https://github.com/LunarBar-app/LunarBar/wiki)以获取更多说明和示例。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
