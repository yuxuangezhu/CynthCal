{
  "sourceLanguage": "en",
  "strings": {
    " (%lld day ago)": {
      "comment": "Label format for dates in the past, e.g., (10 days ago)",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": " (%lld day ago)"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": " (%lld days ago)"
                }
              }
            }
          }
        },
        "zh-Hans": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "（%lld天前）"
                }
              }
            }
          }
        },
        "zh-Hant": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "（%lld天前）"
                }
              }
            }
          }
        }
      }
    },
