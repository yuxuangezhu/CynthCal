          "stringUnit": {
            "state": "translated",
            "value": "請輸入天氣背景所用的城市名，如 北京 或 東京。"
          }
        }
      }
    },
    "Please enter a font size (in points) for the custom text icon, e.g. 13. Leave it empty to use the default size.": {
      "comment": "[Alert] Explanation for custom icon font size",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
