          "stringUnit": {
            "state": "translated",
            "value": "Grant CynthCal permission to display items in the Reminders app.\n\nThis is optional, you can change permissions in the system privacy settings, this dialog will not reappear."
          }
        },
        "zh-Hans": {
          "stringUnit": {
